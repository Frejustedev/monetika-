# Monétika — variables d'environnement
# Copiez ce fichier en `.env.local` (dev) ou configurez-le sur Vercel (prod).

# ———— Base de données (Neon, Postgres serverless) ————
# URL poolée via PgBouncer pour l'app (runtime)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/monetika?sslmode=require"
# URL directe pour les migrations Prisma (shadow DB & migrate deploy)
DIRECT_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/monetika?sslmode=require"

# ———— Auth.js v5 ————
# Clé de signature des cookies (32 bytes base64).
# Générer la vôtre : openssl rand -base64 32
# ou Node : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="REMPLACEZ_PAR_UNE_CLE_GENEREE_LOCALEMENT"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ———— Envoi d'e-mails magic links (Resend recommandé) ————
# Jusqu'à réception de la clé, on loggue en console (voir lib/auth/email.ts)
RESEND_API_KEY=""
EMAIL_FROM="Monétika <no-reply@monetika.app>"

# ———— Stockage des reçus (Vercel Blob, optionnel en V1) ————
BLOB_READ_WRITE_TOKEN=""

# ———— CRON NEF (protège /api/cron/compute-nef) ————
CRON_SECRET="remplacer-par-une-valeur-aleatoire-longue"

# ———— URL publique ————
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ———— Observabilité (optionnel) ————
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
